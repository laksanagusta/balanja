{$SITE_ADDRESS::80} {
	encode zstd gzip

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}

	handle /healthz {
		reverse_proxy api:8080
	}
	handle /readyz {
		reverse_proxy api:8080
	}
	handle /api/* {
		reverse_proxy api:8080
	}
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
