# API runtime values
PORT=8080
DATABASE_URL=postgres://balanja_runtime:password@<supavisor-host>:5432/postgres?sslmode=require
CLERK_ISSUER_URL=https://your-clerk-issuer
CLERK_AUDIENCE=balanja
ALLOWED_ORIGINS=http://localhost:5173
DB_MAX_CONNS=10
SHUTDOWN_TIMEOUT=10s

# Cloudflare R2 product photos (keep disabled until every value is configured)
R2_ENABLED=false
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=balanja-product-images
R2_PUBLIC_BASE_URL=https://images.example.com
